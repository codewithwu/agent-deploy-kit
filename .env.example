# === Database ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=app
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/app
DATABASE_ASYNC_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/app

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0
REDIS_URL=redis://:changeme@localhost:6379/0

# === Auth (REQUIRED in prod) ===
# 至少 16 字节；生产用 32 字节随机 hex
JWT_SECRET=please-generate-32-bytes-random-hex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
LOGIN_RATE_LIMIT_PER_MIN=5
